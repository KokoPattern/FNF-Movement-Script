local function ListenForPartnerMessages()
    local function parseMsg(msgText)
        local sender = string.match(msgText, "From: (.+)") or string.match(msgText, "^%[?([^:]+)%]?") 
        if not sender or sender == LocalPlayer.Name then return end

        if string.match(msgText, "%[FNF_REQ%]") then
            HandleIncomingPartnerRequest(sender)
        elseif string.match(msgText, "%[FNF_ACCEPT%]") then
            PartnerSystem.IsPartnered = true
            PartnerSystem.IsLeader = true
            PartnerSystem.ActivePartner = Players:FindFirstChild(sender)
            SendNotification("PARTNER ACCEPTED", sender .. " is now following your movement!", 4)
            SendNotification("PARTNER SYNC", "Partnering sync is now usable in time events", 6)
            UpdatePartnerHighlight()
            TogglePartnerEventsButtonUI(true)
        elseif string.match(msgText, "%[FNF_DECLINE%]") then
            SendNotification("PARTNER DECLINED", sender .. " declined your request.", 4)
        elseif string.match(msgText, "%[FNF_ACT%]:(.+)") then
            local actionName = string.match(msgText, "%[FNF_ACT%]:(.+)")
            if PartnerSystem.ActivePartner and sender == PartnerSystem.ActivePartner.Name then
                if CombatActions[actionName] then CombatActions[actionName]() end
            end
        end
    end
    
    pcall(function()
        if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
            TextChatService.MessageReceived:Connect(function(textChatMessage)
                if string.match(textChatMessage.Text, "%[FNF_") then
                    parseMsg(textChatMessage.Text)
                end
            end)
        else
            ReplicatedStorage.DefaultChatSystemChatEvents.OnMessageDoneFiltering.OnClientEvent:Connect(function(msgData)
                if string.match(msgData.Message, "%[FNF_") then
                    parseMsg(msgData.Message)
                end
            end)
        end
    end)
end
task.spawn(ListenForPartnerMessages)


