        bv.Parent = RootPart
        CreateTween(RootPart, 0.4, {CFrame = targetCFrame}, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        task.delay(0.4, function() if bv then bv:Destroy() end end)
    end,
