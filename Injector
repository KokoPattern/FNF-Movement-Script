local CurrentHue, CurrentSat, CurrentVal = 0, 1, 1
local DraggingSV, DraggingHue = false, false

local function UpdateColorOutput()
    GlobalColorUpdate(Color3.fromHSV(CurrentHue, CurrentSat, CurrentVal))
end

local function UpdateSV(input)
    local relX = math.clamp(input.Position.X - SatValFrame.AbsolutePosition.X, 0, SatValFrame.AbsoluteSize.X)
    local relY = math.clamp(input.Position.Y - SatValFrame.AbsolutePosition.Y, 0, SatValFrame.AbsoluteSize.Y)
    CurrentSat = relX / SatValFrame.AbsoluteSize.X
    CurrentVal = 1 - (relY / SatValFrame.AbsoluteSize.Y)
    SVKnob.Position = UDim2.new(CurrentSat, 0, 1 - CurrentVal, 0)
    UpdateColorOutput()
end

local function UpdateHue(input)
    local relY = math.clamp(input.Position.Y - HueFrame.AbsolutePosition.Y, 0, HueFrame.AbsoluteSize.Y)
    
    -- FIXED MATH: Align exact visual gradient bounds with absolute hue representation
    CurrentHue = relY / HueFrame.AbsoluteSize.Y
    
    HueKnob.Position = UDim2.new(0.5, 0, relY / HueFrame.AbsoluteSize.Y, 0)
    SatValFrame.BackgroundColor3 = Color3.fromHSV(CurrentHue, 1, 1)
    UpdateColorOutput()
end

