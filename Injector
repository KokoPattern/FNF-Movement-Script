local CombatActions = {
    ["Dash"] = function()
        local targetPos
        if UIConfig.CurrentTarget and UIConfig.CurrentTarget.Character then targetPos = UIConfig.CurrentTarget.Character.HumanoidRootPart.Position else targetPos = RootPart.Position + (RootPart.CFrame.LookVector * 40) end
        local distance = (RootPart.Position - targetPos).Magnitude
        local duration = math.clamp(distance / UIConfig.MovementSpeed, 0.2, 1.5)
        local targetCFrame = CFrame.lookAt(targetPos, targetPos + (targetPos - RootPart.Position))
        if UIConfig.CurrentTarget then targetCFrame = CFrame.lookAt(targetPos - (CFrame.lookAt(RootPart.Position, targetPos).LookVector * 4), targetPos) end
        local bv = Instance.new("BodyVelocity")
        bv.MaxForce = Vector3.new(100000, 100000, 100000)
        bv.Velocity = Vector3.new(0, 0, 0)
        bv.Parent = RootPart
        CreateTween(RootPart, duration, {CFrame = targetCFrame}, Enum.EasingStyle.Quart, Enum.EasingDirection.Out).Completed:Connect(function() if bv then bv:Destroy() end end)
    end,
    ["Dodge Left"] = function()
        local targetCFrame = GetOrientedCFrame(Vector3.new(-15, 0, 0))
        local bv = Instance.new("BodyVelocity")
        bv.MaxForce = Vector3.new(100000, 0, 100000)
