local function GlobalColorUpdate(color)
    CurrentTheme.Primary = color
    local h, s, v = Color3.toHSV(color)
    CurrentTheme.Background = Color3.fromHSV(h, s * 0.8, v * 0.1)
    CurrentTheme.Panel = Color3.fromHSV(h, s * 0.7, v * 0.15)
    
    for _, elem in pairs(DynamicUIElements.PrimaryText) do
        if elem and elem.Parent then elem.TextColor3 = CurrentTheme.Primary end
    end
    for _, elem in pairs(DynamicUIElements.Borders) do
        if elem and elem.Parent then elem.Color = CurrentTheme.Primary end
    end
    for _, elem in pairs(DynamicUIElements.Fills) do
        if elem and elem.Parent then elem.BackgroundColor3 = CurrentTheme.Primary end
    end
    for _, elem in pairs(DynamicUIElements.Backgrounds) do
        if elem and elem.Parent then elem.BackgroundColor3 = CurrentTheme.Background end
    end
    for _, elem in pairs(DynamicUIElements.Panels) do
        if elem and elem.Parent then elem.BackgroundColor3 = CurrentTheme.Panel end
    end
    if UIConfig.TargetHighlight then
        UIConfig.TargetHighlight.FillColor = CurrentTheme.Primary
        UIConfig.TargetHighlight.OutlineColor = CurrentTheme.Primary
    end
end

local function ParseAudioInput(inputString)
    if string.match(inputString, "youtube%.com") or string.match(inputString, "youtu%.be") then
        return nil, "yt_error"
    end
    local cleanId = string.match(inputString, "%d+")
    if cleanId then return "rbxassetid://" .. cleanId, "audio" end
    return nil, "invalid"
end

function GetOrientedCFrame(offsetVector)
    if UIConfig.CurrentTarget and UIConfig.CurrentTarget.Character and UIConfig.CurrentTarget.Character:FindFirstChild("HumanoidRootPart") then
        local targetRoot = UIConfig.CurrentTarget.Character.HumanoidRootPart
        return CFrame.lookAt(RootPart.Position, targetRoot.Position) * CFrame.new(offsetVector)
    else
        return RootPart.CFrame * CFrame.new(offsetVector)
    end
end


