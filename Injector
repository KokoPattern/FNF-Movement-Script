-- FLawless Player Search Algorithm
local function FindPlayer(targetString)
    if not targetString or targetString == "" then return nil end
    local search = string.lower(string.match(targetString, "^%s*(.-)%s*$"))
    if search == "" then return nil end
    
    -- Pass 1: Exact Match
    for _, player in pairs(Players:GetPlayers()) do
        if string.lower(player.Name) == search or string.lower(player.DisplayName) == search then
            return player
        end
    end
    -- Pass 2: Partial Match
    for _, player in pairs(Players:GetPlayers()) do
        if string.find(string.lower(player.Name), search, 1, true) or string.find(string.lower(player.DisplayName), search, 1, true) then
            return player
        end
    end
    return nil
end

local function CreateTween(instance, duration, properties, easingStyle, easingDirection)
    local style = easingStyle or Enum.EasingStyle.Quad
    local direction = easingDirection or Enum.EasingDirection.Out
    local tweenInfo = TweenInfo.new(duration, style, direction)
    local tween = TweenService:Create(instance, tweenInfo, properties)
    tween:Play()
    return tween
end

local function PlayAnimation(animId, speed, looped)
    if not Humanoid or not Humanoid:FindFirstChild("Animator") then return nil end
    local idString = "rbxassetid://" .. tostring(animId)
    local animator = Humanoid.Animator
    
    if LoadedAnimations[idString] then
        local track = LoadedAnimations[idString]
        track.Looped = looped or false
        track:Play()
        track:AdjustSpeed(speed or 1)
        return track
    else
        local animation = Instance.new("Animation")
        animation.AnimationId = idString
        local success, track = pcall(function() return animator:LoadAnimation(animation) end)
        if success and track then
            LoadedAnimations[idString] = track
            track.Looped = looped or false
            track:Play()
            track:AdjustSpeed(speed or 1)
            return track
        end
    end
    return nil
end

local function StopAnimation(animId)
    local idString = "rbxassetid://" .. tostring(animId)
    if LoadedAnimations[idString] then
        LoadedAnimations[idString]:Stop(0.2)
    end
end

